MINIMAX_API_KEY=your_key_here
MINIMAX_BASE_URL=https://api.minimax.chat/v1
MINIMAX_MODEL=MiniMax-text-01
# Embeddings: openrouter (default) or ollama. MiniMax is LLM-only.
EMBEDDING_PROVIDER=openrouter
EMBEDDING_BATCH_SIZE=8
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_EMBEDDING_MODEL=qwen/qwen3-embedding-8b
# Local Ollama (EMBEDDING_PROVIDER=ollama). Native qwen3-embedding:4b is 2560 dims;
# set EMBEDDING_DIMENSIONS to match PGVECTOR_DIMENSIONS (≤2000 for HNSW).
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_EMBEDDING_MODEL=qwen3-embedding:4b
EMBEDDING_DIMENSIONS=1536
EMBEDDING_MAX_RETRIES=5

DATABASE_URL=postgres://cyber:cyber@localhost:5432/vendor_threat_watch
PGVECTOR_DIMENSIONS=1536
REDIS_HOST=localhost
REDIS_PORT=6379

RSS_FETCH_INTERVAL_MINUTES=30
HTTP_EXTRACTION_CONCURRENCY=10
PLAYWRIGHT_EXTRACTION_CONCURRENCY=2
PLAYWRIGHT_EXTRACTION_TIMEOUT_MS=15000
PLAYWRIGHT_MIN_TEXT_LENGTH=250
LLM_CONCURRENCY=3
LLM_TIMEOUT_MS=60000
ALERT_SUPPRESSION_HOURS=6
EARLY_WARNING_WINDOW_HOURS=24
ALERT_LATENCY_SLO_HOURS=2
MIN_ALERT_CONFIDENCE=0.75

# Enterprise HTTP proxy (off by default). When enabled, sets an undici global
# dispatcher (EnvHttpProxyAgent) so all undici/`fetch` calls in this process —
# article HTTP extraction, embeddings, LLM if it uses fetch — go through the
# proxy. RSS-parser and Playwright are out of scope for this branch.
# HTTP_PROXY and HTTPS_PROXY are required when enabled. NO_PROXY is optional;
# when unset, defaults to "localhost,127.0.0.1,::1" so local services
# (e.g. local Ollama) stay direct. URLs with userinfo (http://user:pass@host)
# are logged without the userinfo.
HTTP_PROXY_ENABLED=false
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=

# Next.js public web + analyst workspace (Auth.js / GitHub).
# Generate AUTH_SECRET with: openssl rand -base64 32
# Local callback:  http://localhost:3000/api/auth/callback/github
# Prod callback:   ${AUTH_URL}/api/auth/callback/github  (set AUTH_URL below)
AUTH_SECRET=
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
# Public site origin in production (no trailing slash), e.g. https://threats.example.com
# Required for correct GitHub OAuth redirects behind Cloudflare. Optional locally.
AUTH_URL=
# Comma/whitespace GitHub usernames allowed into /workspace. Empty = deny all.
ANALYST_GITHUB_USERS=
