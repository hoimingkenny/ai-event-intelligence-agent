# syntax=docker/dockerfile:1
# Next.js web image (public catalogue + analyst workspace). Build context is the
# repo root so `web/` can import shared modules from `src/` (externalDir).
FROM node:22-bookworm-slim AS root-deps
WORKDIR /app
COPY package.json package-lock.json ./
RUN npm ci

FROM node:22-bookworm-slim AS web-deps
WORKDIR /app
COPY web/package.json web/package-lock.json ./web/
RUN cd web && npm ci

FROM node:22-bookworm-slim AS builder
WORKDIR /app
# Fail closed: root typecheck must pass before we produce a production image.
# (Next's in-tree check of parent src/ under web/tsconfig is unreliable; DOCKER_BUILD
# skips that path only after this gate.)
COPY package.json package-lock.json tsconfig.json ./
COPY --from=root-deps /app/node_modules ./node_modules
COPY src ./src
COPY scripts ./scripts
COPY eval ./eval
RUN npm run check

COPY --from=web-deps /app/web/node_modules ./web/node_modules
COPY web ./web
WORKDIR /app/web
ENV NEXT_TELEMETRY_DISABLED=1
ENV DOCKER_BUILD=1
RUN npm run build

FROM node:22-bookworm-slim AS runtime
WORKDIR /app
ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1
ENV PORT=3000
ENV HOSTNAME=0.0.0.0
COPY --from=builder /app/web/public ./web/public
COPY --from=builder /app/web/.next/standalone ./
COPY --from=builder /app/web/.next/static ./web/.next/static
USER node
EXPOSE 3000
CMD ["node", "web/server.js"]
